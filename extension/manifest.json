{
  "manifest_version": 3,
  "name": "Memora",
  "version": "1.0",
  "description": "Save anything to your second brain",
  
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://memora-8xw8.onrender.com/*"],

  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Memora"
  },
  
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}
